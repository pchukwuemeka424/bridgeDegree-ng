<style>
  .apply-page { padding: 32px 0 48px; background: #244267; color: rgba(255,255,255,0.95); }
  .apply-hero { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; margin-bottom: 32px; }
  .apply-hero h1 { font-family: 'DM Serif Display', serif; font-size: clamp(1.75rem, 2.5vw, 2.25rem); font-weight: 400; margin: 0; color: #fff; }
  .success-card { max-width: 520px; margin: 0 auto; background: var(--surface); border-radius: 20px; padding: 40px; box-shadow: 0 4px 32px rgba(0,0,0,0.08); border: 1px solid var(--border); }
  .success-icon { width: 64px; height: 64px; margin: 0 auto 20px; background: var(--accent-green-soft); color: var(--accent-green); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
  .success-card h2 { font-family: 'DM Serif Display', serif; font-size: 1.5rem; margin-bottom: 12px; color: var(--text); }
  .success-card .app-id { font-size: 1.25rem; font-weight: 700; color: var(--accent-green); margin: 16px 0; letter-spacing: 0.05em; }
  .success-card a { color: var(--accent-green); font-weight: 600; }
</style>

<section class="apply-page">
  <div class="container">
    <div class="apply-hero">
      <h1>Application received</h1>
      <a href="/students" style="color: rgba(255,255,255,0.9); font-weight: 600;"><i data-lucide="arrow-left"></i> Back to Students</a>
    </div>
  </div>
</section>

<section class="page-section" style="padding-top: 32px;">
  <div class="container">
    <div class="success-card">
      <div class="success-icon"><i data-lucide="check"></i></div>
      <h2>Thank you for applying</h2>
      <p>Your application has been received. A BridgeDegree advisor will be in touch within 48 hours.</p>
      <p><strong>Save your Application ID to check status anytime:</strong></p>
      <p class="app-id"><%= applicationId %></p>
      <p><a href="/student/login">View my application status</a> — use the email you applied with and the Application ID above.</p>
    </div>
  </div>
</section>
