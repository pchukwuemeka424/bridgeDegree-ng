<div class="blog-single">
  <div class="blog-single__container">
    <article class="blog-single__main">
      <header class="blog-single__header">
        <p class="blog-single__meta">
          <time datetime="<%= post.createdAt ? new Date(post.createdAt).toISOString() : '' %>">
            <%= post.createdAt ? new Date(post.createdAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) : '' %>
          </time>
        </p>
        <h1 class="blog-single__title"><%= post.title %></h1>
        <% if (post.excerpt) { %><p class="blog-single__excerpt"><%= post.excerpt %></p><% } %>
      </header>
      <% if (post.image) { %>
        <figure class="blog-single__figure">
          <img src="<%= post.image %>" alt="" class="blog-single__img">
        </figure>
      <% } %>
      <div class="blog-single__content blog-single__content--rich">
        <%- typeof contentHtml !== 'undefined' ? contentHtml : '' %>
      </div>
      <footer class="blog-single__footer">
        <a href="/blog" class="blog-single__back">← Back to Blog</a>
      </footer>
    </article>

    <aside class="blog-single__sidebar">
      <div class="blog-sidebar__card">
        <h3 class="blog-sidebar__title">Recent posts</h3>
        <ul class="blog-sidebar__list">
          <% if (typeof recentPosts !== 'undefined' && recentPosts && recentPosts.length) { %>
            <% recentPosts.forEach(function(p) { %>
            <li class="blog-sidebar__item">
              <a href="/blog/<%= p.slug %>" class="blog-sidebar__link">
                <% if (p.image) { %>
                  <span class="blog-sidebar__thumb"><img src="<%= p.image %>" alt=""></span>
                <% } %>
                <span class="blog-sidebar__text">
                  <span class="blog-sidebar__post-title"><%= p.title %></span>
                  <span class="blog-sidebar__date"><%= p.createdAt ? new Date(p.createdAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) : '' %></span>
                </span>
              </a>
            </li>
            <% }); %>
          <% } else { %>
            <li class="blog-sidebar__item"><a href="/blog" class="blog-sidebar__link">View all posts</a></li>
          <% } %>
        </ul>
      </div>
      <div class="blog-sidebar__card">
        <h3 class="blog-sidebar__title">Explore</h3>
        <a href="/blog" class="blog-sidebar__cta">All blog posts</a>
        <a href="/" class="blog-sidebar__cta">Home</a>
      </div>
    </aside>
  </div>
</div>

<style>
.blog-single { padding: 48px 0 64px; }
.blog-single__container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 48px;
  align-items: start;
}
@media (max-width: 900px) {
  .blog-single__container { grid-template-columns: 1fr; }
  .blog-single__sidebar { order: -1; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
}
@media (max-width: 600px) {
  .blog-single__sidebar { grid-template-columns: 1fr; }
}
.blog-single__main { min-width: 0; }
.blog-single__header { margin-bottom: 28px; }
.blog-single__meta {
  font-size: 0.875rem;
  color: var(--text-muted);
  margin-bottom: 12px;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.blog-single__title {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(1.85rem, 4vw, 2.5rem);
  font-weight: 400;
  line-height: 1.25;
  color: var(--text);
  margin: 0 0 12px 0;
}
.blog-single__excerpt {
  font-size: 1.1rem;
  color: var(--text-muted);
  line-height: 1.6;
  margin: 0;
}
.blog-single__figure { margin: 0 0 32px 0; border-radius: var(--radius); overflow: hidden; background: var(--surface-2); }
.blog-single__img {
  width: 100%;
  height: auto;
  max-height: 420px;
  object-fit: cover;
  display: block;
}
.blog-single__content {
  font-size: 1.0625rem;
  line-height: 1.8;
  color: var(--text);
}
.blog-single__content p { margin-bottom: 1.35em; }
.blog-single__content p:last-child { margin-bottom: 0; }
.blog-single__content h2,
.blog-single__content h3 {
  font-family: 'DM Serif Display', serif;
  font-weight: 400;
  line-height: 1.3;
  margin: 1.5em 0 0.65em;
  color: var(--text);
}
.blog-single__content h2 { font-size: 1.65rem; }
.blog-single__content h3 { font-size: 1.35rem; }
.blog-single__content ul,
.blog-single__content ol { margin: 0 0 1.25em; padding-left: 1.35em; }
.blog-single__content li { margin-bottom: 0.5em; }
.blog-single__content blockquote {
  margin: 1.25em 0;
  padding: 0.75em 0 0.75em 1.15em;
  border-left: 4px solid var(--accent-green);
  color: var(--text-muted);
  font-style: italic;
}
.blog-single__content a { color: var(--accent-green); text-decoration: none; }
.blog-single__content a:hover { text-decoration: underline; }
.blog-single__footer { margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--border); }
.blog-single__back {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--accent-green);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.blog-single__back:hover { text-decoration: underline; }

.blog-sidebar__card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 24px;
  margin-bottom: 24px;
  box-shadow: var(--shadow);
}
.blog-sidebar__card:last-child { margin-bottom: 0; }
.blog-sidebar__title {
  font-size: 0.8rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-muted);
  margin: 0 0 18px 0;
  padding-bottom: 10px;
  border-bottom: 2px solid var(--accent-green);
}
.blog-sidebar__list { list-style: none; margin: 0; padding: 0; }
.blog-sidebar__item { margin-bottom: 2px; }
.blog-sidebar__item:last-child { margin-bottom: 0; }
.blog-sidebar__link {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 12px 0;
  text-decoration: none;
  color: var(--text);
  border-bottom: 1px solid var(--border);
  transition: background 0.15s, color 0.15s;
}
.blog-sidebar__item:last-child .blog-sidebar__link { border-bottom: none; }
.blog-sidebar__link:hover { color: var(--accent-green); }
.blog-sidebar__link:hover .blog-sidebar__post-title { color: var(--accent-green); }
.blog-sidebar__thumb {
  width: 56px;
  height: 56px;
  flex-shrink: 0;
  border-radius: 10px;
  overflow: hidden;
  background: var(--surface-2);
}
.blog-sidebar__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
.blog-sidebar__text { min-width: 0; display: flex; flex-direction: column; gap: 4px; }
.blog-sidebar__post-title {
  font-size: 0.95rem;
  font-weight: 600;
  line-height: 1.35;
  color: var(--text);
  transition: color 0.15s;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.blog-sidebar__date { font-size: 0.8rem; color: var(--text-muted); }
.blog-sidebar__cta {
  display: block;
  padding: 10px 0;
  font-size: 0.95rem;
  font-weight: 500;
  color: var(--accent-green);
  text-decoration: none;
  transition: color 0.15s, padding-left 0.15s;
}
.blog-sidebar__cta:hover { color: var(--accent-green-bright); padding-left: 6px; }
.blog-sidebar__cta + .blog-sidebar__cta { border-top: 1px solid var(--border); }
</style>
