<style>
  .blog-hero { padding: 56px 0 40px; text-align: center; background: #244267; border-bottom: 1px solid rgba(255,255,255,0.1); color: #fff; }
  .blog-hero h1 { font-family: 'DM Serif Display', serif; font-size: clamp(1.75rem, 2.8vw, 2.25rem); font-weight: 400; margin-bottom: 12px; color: #fff; line-height: 1.3; }
  .blog-hero .meta { font-size: 0.9rem; color: rgba(255,255,255,0.85); }
  .blog-article { max-width: 720px; margin: 0 auto; padding: 48px 24px 64px; }
  .blog-article .lead-img { width: 100%; max-height: 400px; object-fit: cover; border-radius: var(--radius); margin-bottom: 32px; background: var(--surface-2); }
  .blog-article .content { font-size: 1.05rem; line-height: 1.75; color: var(--text); }
  .blog-article .content p { margin-bottom: 1.25em; }
</style>

<section class="blog-hero">
  <div class="container">
    <h1><%= post.title %></h1>
    <p class="meta"><%= post.createdAt ? new Date(post.createdAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) : '' %></p>
  </div>
</section>

<article class="blog-article">
  <% if (post.image) { %><img src="<%= post.image %>" alt="" class="lead-img"><% } %>
  <div class="content">
    <%- typeof post.content === 'string' ? post.content.replace(/\n/g, '<br>') : '' %>
  </div>
</article>
