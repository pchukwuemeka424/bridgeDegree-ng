  .about-value .icon { width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; background: var(--accent-green-soft); border-radius: var(--radius-sm); color: var(--accent-green); margin-bottom: 16px; }
  .about-value .icon .lucide { width: 24px; height: 24px; }
