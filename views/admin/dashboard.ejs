<nav class="admin-breadcrumb">/ <a href="/admin">Dashboard</a></nav>
<div class="admin-page-header">
  <h1 class="admin-page-title"><i data-lucide="layout-dashboard"></i> Dashboard</h1>
  <p class="admin-page-desc">Overview of your BridgeDegree admin content and activity.</p>
</div>

<div class="admin-stats">
  <div class="admin-stat">
    <div class="admin-stat__icon admin-stat__icon--blue"><i data-lucide="file-text"></i></div>
    <div class="admin-stat__content">
      <div class="num"><%= postCount %></div>
      <div class="label">Blog posts</div>
    </div>
  </div>
  <div class="admin-stat">
    <div class="admin-stat__icon admin-stat__icon--green"><i data-lucide="message-square-quote"></i></div>
    <div class="admin-stat__content">
      <div class="num"><%= typeof testimonialCount !== 'undefined' ? testimonialCount : 0 %></div>
      <div class="label">Testimonials</div>
    </div>
  </div>
  <div class="admin-stat">
    <div class="admin-stat__icon admin-stat__icon--orange"><i data-lucide="users"></i></div>
    <div class="admin-stat__content">
      <div class="num"><%= applicationCount %></div>
      <div class="label">Student applications</div>
    </div>
  </div>
  <div class="admin-stat">
    <div class="admin-stat__icon admin-stat__icon--purple"><i data-lucide="building-2"></i></div>
    <div class="admin-stat__content">
      <div class="num"><%= typeof partnerCount !== 'undefined' ? partnerCount : 0 %></div>
      <div class="label">Partners</div>
    </div>
  </div>
</div>

<div class="admin-card">
  <h2 class="admin-card__title">Quick actions</h2>
  <div class="admin-actions">
    <a href="/admin/blog/new" class="admin-btn admin-btn-primary"><i data-lucide="plus"></i> New blog post</a>
    <a href="/admin/blog" class="admin-btn admin-btn-secondary">Manage blog</a>
    <a href="/admin/testimonials/new" class="admin-btn admin-btn-secondary">New testimonial</a>
    <a href="/admin/testimonials" class="admin-btn admin-btn-secondary">Manage testimonials</a>
    <a href="/admin/partners/new" class="admin-btn admin-btn-secondary">New partner</a>
    <a href="/admin/partners" class="admin-btn admin-btn-secondary">Manage partners</a>
    <a href="/admin/hero" class="admin-btn admin-btn-secondary">Edit home hero</a>
    <a href="/admin/applications" class="admin-btn admin-btn-secondary">View applications</a>
  </div>
</div>
