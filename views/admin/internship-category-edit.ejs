<nav class="admin-breadcrumb">/ <a href="/admin">Dashboard</a> / <a href="/admin/internship-categories">Categories</a> / <%= category ? 'Edit' : 'New' %></nav>
<div class="admin-page-header">
  <h1 class="admin-page-title"><i data-lucide="folder-tree"></i> <%= category ? 'Edit category' : 'New category' %></h1>
</div>
<div class="admin-actions">
  <a href="/admin/internship-categories" class="admin-btn admin-btn-secondary">Back to categories</a>
</div>
<div class="admin-card">
  <% if (typeof error !== 'undefined' && error) { %>
  <p class="admin-error"><%= error %></p>
  <% } %>
  <form method="post" action="<%= category ? '/admin/internship-categories/' + category._id : '/admin/internship-categories' %>">
    <div class="admin-form-group">
      <label for="name">Category name *</label>
      <input type="text" id="name" name="name" required value="<%= category ? (category.name || '') : '' %>" placeholder="e.g. Remote placements">
    </div>
    <div class="admin-form-group">
      <label for="description">Description (optional)</label>
      <textarea id="description" name="description" rows="3" placeholder="Short note for admins"><%= category ? (category.description || '') : '' %></textarea>
    </div>
    <div class="admin-form-group">
      <label for="sortOrder">Display order (lower = first)</label>
      <input type="number" id="sortOrder" name="sortOrder" value="<%= category ? (category.sortOrder ?? 0) : 0 %>" min="0">
    </div>
    <div class="admin-form-group">
      <label><input type="checkbox" name="active" <%= (category && category.active !== false) || !category ? 'checked' : '' %>> Active (available when creating internships)</label>
    </div>
    <button type="submit" class="admin-btn admin-btn-primary"><%= category ? 'Update' : 'Create' %> category</button>
  </form>
</div>
