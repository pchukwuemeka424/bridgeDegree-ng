<nav class="admin-breadcrumb">/ <a href="/admin">Dashboard</a> / Blog</nav>
<div class="admin-page-header">
  <h1 class="admin-page-title"><i data-lucide="file-text"></i> Blog posts</h1>
  <p class="admin-page-desc">Create and manage blog posts for the public site.</p>
</div>

<div class="admin-actions">
  <a href="/admin/blog/new" class="admin-btn admin-btn-primary"><i data-lucide="plus"></i> New post</a>
  <a href="/admin" class="admin-btn admin-btn-secondary">Back to dashboard</a>
</div>

<div class="admin-card">
  <% if (posts && posts.length) { %>
  <table class="admin-table">
    <thead>
      <tr>
        <th>Title</th>
        <th>Status</th>
        <th>Date</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% posts.forEach(function(p) { %>
      <tr>
        <td><%= p.title %></td>
        <td><span class="admin-badge <%= p.published ? 'admin-badge-published' : 'admin-badge-draft' %>"><%= p.published ? 'Published' : 'Draft' %></span></td>
        <td><%= p.createdAt ? new Date(p.createdAt).toLocaleDateString() : '' %></td>
        <td class="actions">
          <a href="/blog/<%= p.slug %>" target="_blank" class="admin-btn admin-btn-secondary">View</a>
          <a href="/admin/blog/<%= p._id %>/edit" class="admin-btn admin-btn-secondary">Edit</a>
          <form method="post" action="/admin/blog/<%= p._id %>/delete" style="display:inline;" onsubmit="return confirm('Delete this post?');">
            <button type="submit" class="admin-btn admin-btn-danger">Delete</button>
          </form>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } else { %>
  <p>No posts yet. <a href="/admin/blog/new" class="admin-btn admin-btn-primary" style="margin-top:12px;">Create your first post</a></p>
  <% } %>
</div>
