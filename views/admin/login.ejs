<div class="admin-login">
  <div class="admin-login__card">
    <div class="admin-login__brand">
      <img src="/images/logo.png" alt="Bridge Degree" class="admin-login__logo">
      <p class="admin-login__brand-tag">Admin</p>
    </div>
    <% if (typeof error !== 'undefined' && error) { %>
    <p class="admin-login__error"><%= error %></p>
    <% } %>
    <form method="post" action="/admin/login">
      <p class="admin-login__title">Sign in to your account</p>
      <div class="admin-form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required autocomplete="email" placeholder="admin@bridgedegree.com">
      </div>
      <div class="admin-form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required autocomplete="current-password" placeholder="••••••••">
      </div>
      <button type="submit" class="admin-login__submit">Sign in</button>
    </form>
    <p class="admin-login__links">
      <a href="/admin">Go to dashboard</a>
      <span>·</span>
      <a href="/">← Back to site</a>
    </p>
  </div>
</div>
