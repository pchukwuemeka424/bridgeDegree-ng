<nav class="admin-breadcrumb">/ <a href="/admin">Dashboard</a> / <a href="/admin/blog">Blog</a> / <%= post ? 'Edit' : 'New' %></nav>
<div class="admin-page-header">
  <h1 class="admin-page-title"><i data-lucide="file-text"></i> <%= post ? 'Edit post' : 'New post' %></h1>
</div>
<div class="admin-actions">
  <a href="/admin/blog" class="admin-btn admin-btn-secondary">Back to blog</a>
</div>
<% if (typeof error !== 'undefined' && error) { %>
<div class="admin-card admin-error-card" style="margin-bottom: 16px; border-color: var(--admin-accent-red, #ef4444); background: #fef2f2;">
  <p style="margin: 0; color: var(--admin-accent-red, #ef4444);"><%= error %></p>
</div>
<% } %>
<div class="admin-card">
  <form method="post" action="<%= post ? '/admin/blog/' + post._id : '/admin/blog' %>" enctype="multipart/form-data">
    <div class="admin-form-group">
      <label for="title">Title *</label>
      <input type="text" id="title" name="title" required value="<%= post ? (post.title || '') : '' %>">
    </div>
    <div class="admin-form-group">
      <label for="excerpt">Excerpt (short summary)</label>
      <textarea id="excerpt" name="excerpt" placeholder="Optional"><%= post ? (post.excerpt || '') : '' %></textarea>
    </div>
    <div class="admin-form-group admin-form-group--quill">
      <label for="blog-editor">Content *</label>
      <p class="admin-form-hint">Use the toolbar for bold, links, lists, and headings.</p>
      <div id="blog-editor" class="admin-quill-editor" aria-label="Post content"></div>
      <input type="hidden" name="content" id="content-input" value="">
      <script type="application/json" id="blog-initial-json"><%- JSON.stringify(post ? (post.content || '') : '') %></script>
    </div>
    <div class="admin-form-group">
      <label for="image">Image</label>
      <% if (post && post.image) { %>
      <p style="margin-bottom: 8px;"><img src="<%= post.image %>" alt="" style="max-width: 200px; height: auto; border-radius: 8px;"></p>
      <% } %>
      <input type="file" id="image" name="image" accept="image/jpeg,image/png,image/gif,image/webp">
    </div>
    <div class="admin-form-group">
      <label><input type="checkbox" name="published" <%= (post && post.published) || !post ? 'checked' : '' %>> Published</label>
    </div>
    <button type="submit" class="admin-btn admin-btn-primary"><%= post ? 'Update' : 'Create' %> post</button>
  </form>
</div>
<script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
<script>
(function () {
  var el = document.getElementById('blog-editor');
  var input = document.getElementById('content-input');
  var jsonEl = document.getElementById('blog-initial-json');
  if (!el || !input || typeof Quill === 'undefined') return;

  var toolbarOptions = [
    [{ header: [1, 2, 3, false] }],
    ['bold', 'italic', 'underline', 'strike'],
    [{ list: 'ordered' }, { list: 'bullet' }],
    ['blockquote', 'link'],
    ['clean']
  ];

  var quill = new Quill('#blog-editor', {
    theme: 'snow',
    placeholder: 'Write your post…',
    modules: {
      toolbar: toolbarOptions
    }
  });

  try {
    var initial = jsonEl ? JSON.parse(jsonEl.textContent || '""') : '';
    if (initial) {
      quill.clipboard.dangerouslyPasteHTML(initial);
    }
  } catch (e) {}

  var form = el.closest('form');
  if (form) {
    form.addEventListener('submit', function (e) {
      var text = quill.getText().replace(/\u00a0/g, ' ').trim();
      if (!text) {
        e.preventDefault();
        alert('Please add some content for the post.');
        quill.focus();
        return;
      }
      input.value = quill.root.innerHTML;
    });
  }
})();
</script>
