<style>
  .blog-hero { padding: 56px 0 40px; text-align: center; background: #244267; border-bottom: 1px solid rgba(255,255,255,0.1); color: #fff; }
  .blog-hero h1 { font-family: 'DM Serif Display', serif; font-size: clamp(1.85rem, 3vw, 2.35rem); font-weight: 400; margin-bottom: 12px; color: #fff; }
  .blog-hero .subtitle { color: rgba(255,255,255,0.92); }
  .blog-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 28px; }
  .blog-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; transition: box-shadow 0.2s, transform 0.2s; }
  .blog-card:hover { box-shadow: var(--shadow-hover); transform: translateY(-2px); }
  .blog-card a { text-decoration: none; color: inherit; display: block; }
  .blog-card .card-img { width: 100%; height: 180px; object-fit: cover; background: var(--surface-2); }
  .blog-card .meta { display: flex; gap: 12px; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 10px; }
  .blog-card .tag { color: var(--accent-green); font-weight: 600; }
  .blog-card h3 { font-size: 1.15rem; font-weight: 700; margin-bottom: 10px; line-height: 1.35; color: var(--text); }
  .blog-card p { font-size: 0.9rem; color: var(--text-muted); line-height: 1.6; }
  .blog-card .card-inner { padding: 24px; }
</style>

<section class="blog-hero">
  <div class="container">
    <h1>Blog</h1>
    <p class="subtitle">Insights on career infrastructure, graduate outcomes, and building proof — not just credentials.</p>
  </div>
</section>

<section class="page-section">
  <div class="container">
    <div class="blog-grid">
      <% if (typeof posts !== 'undefined' && posts && posts.length) { %>
        <% posts.forEach(function(post) { %>
        <article class="blog-card">
          <a href="/blog/<%= post.slug %>">
            <% if (post.image) { %><img src="<%= post.image %>" alt="" class="card-img"><% } %>
            <div class="card-inner">
              <div class="meta">
                <span class="tag">Blog</span>
                <span><%= post.createdAt ? new Date(post.createdAt).toLocaleDateString('en-GB', { month: 'long', year: 'numeric' }) : '' %></span>
              </div>
              <h3><%= post.title %></h3>
              <p><%= post.excerpt || (post.content ? post.content.slice(0, 160) + '…' : '') %></p>
            </div>
          </a>
        </article>
        <% }); %>
      <% } else { %>
        <p style="grid-column: 1/-1; color: var(--text-muted);">No posts yet. Check back soon.</p>
      <% } %>
    </div>
  </div>
</section>
