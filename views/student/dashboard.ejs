<div class="student-dash">
  <header class="student-dash__header">
    <h1 class="student-dash__title">My application</h1>
    <p class="student-dash__desc">View your application status or sign in with your email and password.</p>
  </header>

  <div class="student-dash__tabs" role="tablist" aria-label="Sign in options">
    <button type="button" class="student-dash__tab <%= activeTab === 'view' ? 'student-dash__tab--active' : '' %>" role="tab" aria-selected="<%= activeTab === 'view' %>" aria-controls="panel-view" id="tab-view" data-tab="view">
      <i data-lucide="file-text"></i> View application
    </button>
    <button type="button" class="student-dash__tab <%= activeTab === 'login' ? 'student-dash__tab--active' : '' %>" role="tab" aria-selected="<%= activeTab === 'login' %>" aria-controls="panel-login" id="tab-login" data-tab="login">
      <i data-lucide="log-in"></i> Login
    </button>
  </div>

  <div class="student-dash__card">
    <div id="panel-view" class="student-dash__panel" role="tabpanel" aria-labelledby="tab-view"<%= activeTab !== 'view' ? ' hidden' : '' %>>
      <h2 class="student-dash__card-title">View with application ID</h2>
      <% if (typeof error !== 'undefined' && error && activeTab === 'view') { %>
      <p class="student-dash__error"><%= error %></p>
      <% } %>
      <form method="post" action="/student/dashboard" class="student-dash__form">
        <input type="hidden" name="mode" value="view">
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required placeholder="you@university.edu" value="<%= application && application.email ? application.email : '' %>">
        </div>
        <div class="form-group">
          <label for="applicationId">Application ID</label>
          <input type="text" id="applicationId" name="applicationId" required placeholder="e.g. BD-XXXX" value="<%= application && application.applicationId ? application.applicationId : '' %>">
        </div>
        <button type="submit" class="btn"><i data-lucide="search"></i> View application</button>
      </form>
    </div>

    <div id="panel-login" class="student-dash__panel" role="tabpanel" aria-labelledby="tab-login"<%= activeTab !== 'login' ? ' hidden' : '' %>>
      <h2 class="student-dash__card-title">Login with email and password</h2>
      <% if (typeof error !== 'undefined' && error && activeTab === 'login') { %>
      <p class="student-dash__error"><%= error %></p>
      <% } %>
      <form method="post" action="/student/dashboard" class="student-dash__form">
        <input type="hidden" name="mode" value="login">
        <div class="form-group">
          <label for="login-email">Email</label>
          <input type="email" id="login-email" name="email" required placeholder="you@university.edu" value="<%= application && application.email ? application.email : '' %>">
        </div>
        <div class="form-group">
          <label for="login-password">Password</label>
          <input type="password" id="login-password" name="password" required autocomplete="current-password" placeholder="••••••••">
        </div>
        <button type="submit" class="btn"><i data-lucide="log-in"></i> Sign in</button>
      </form>
      <p class="student-dash__hint">Set a password first using the "View application" tab and your application ID; then you can sign in here.</p>
    </div>
  </div>

  <% if (application) { %>
  <% if (typeof setPasswordSuccess !== 'undefined' && setPasswordSuccess) { %>
  <p class="student-dash__success">Password set. You can now use the Login tab with your email and password.</p>
  <% } %>
  <div class="student-dash__card student-dash__status">
    <div class="student-dash__status-header">
      <h2 class="student-dash__status-title">Application status</h2>
      <span class="student-dash__status-badge admin-badge admin-badge-<%= application.status %>"><%= application.status.replace('_', ' ') %></span>
    </div>
    <div class="student-dash__grid">
      <div class="student-dash__field">
        <div class="student-dash__field-label">Application ID</div>
        <div class="student-dash__field-value"><%= application.applicationId %></div>
      </div>
      <div class="student-dash__field">
        <div class="student-dash__field-label">Name</div>
        <div class="student-dash__field-value"><%= application.firstname %> <%= application.lastname %></div>
      </div>
      <div class="student-dash__field">
        <div class="student-dash__field-label">Email</div>
        <div class="student-dash__field-value"><%= application.email %></div>
      </div>
      <div class="student-dash__field">
        <div class="student-dash__field-label">University</div>
        <div class="student-dash__field-value"><%= application.university %></div>
      </div>
      <div class="student-dash__field">
        <div class="student-dash__field-label">Level</div>
        <div class="student-dash__field-value"><%= application.level %></div>
      </div>
      <div class="student-dash__field">
        <div class="student-dash__field-label">Department</div>
        <div class="student-dash__field-value"><%= application.department %></div>
      </div>
      <div class="student-dash__field">
        <div class="student-dash__field-label">Submitted</div>
        <div class="student-dash__field-value"><%= application.submittedAt ? new Date(application.submittedAt).toLocaleString() : '—' %></div>
      </div>
    </div>

    <% if (!hasPassword) { %>
    <div class="student-dash__set-password">
      <h3 class="student-dash__set-password-title">Set a password for future logins</h3>
      <p class="student-dash__set-password-desc">Use the Login tab next time with your email and this password.</p>
      <form method="post" action="/student/dashboard/set-password" class="student-dash__form student-dash__form--inline">
        <input type="hidden" name="email" value="<%= application.email %>">
        <input type="hidden" name="applicationId" value="<%= application.applicationId %>">
        <div class="form-group">
          <label for="new-password">New password (min 6 characters)</label>
          <input type="password" id="new-password" name="password" required minlength="6" autocomplete="new-password" placeholder="••••••••">
        </div>
        <button type="submit" class="btn">Set password</button>
      </form>
    </div>
    <% } %>
  </div>
  <% } %>

  <% if (typeof setPasswordError !== 'undefined' && setPasswordError) { %>
  <p class="student-dash__error">Could not set password. Use your email and application ID to view your application first, then set a password (min 6 characters).</p>
  <% } %>
</div>

<script>
(function() {
  var tabs = document.querySelectorAll('.student-dash__tab');
  var panels = document.querySelectorAll('.student-dash__panel');
  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var t = this.getAttribute('data-tab');
      tabs.forEach(function(x) { x.classList.remove('student-dash__tab--active'); x.setAttribute('aria-selected', 'false'); });
      panels.forEach(function(p) { p.hidden = true; });
      this.classList.add('student-dash__tab--active');
      this.setAttribute('aria-selected', 'true');
      var panel = document.getElementById('panel-' + t);
      if (panel) { panel.hidden = false; }
      if (typeof lucide !== 'undefined') lucide.createIcons();
    });
  });
})();
</script>
