<div class="sd-page">
  <h1 class="sd-page__title">Password</h1>

  <% if (typeof setPasswordSuccess !== 'undefined' && setPasswordSuccess) { %>
  <div class="sd-alert sd-alert--success">
    <i data-lucide="check-circle"></i>
    <span>Password set. You can now <a href="/student/login?tab=login">sign in</a> with your email and password.</span>
  </div>
  <% } %>
  <% if (typeof changePasswordSuccess !== 'undefined' && changePasswordSuccess) { %>
  <div class="sd-alert sd-alert--success">
    <i data-lucide="check-circle"></i>
    <span>Password updated. Use your new password next time you sign in.</span>
  </div>
  <% } %>
  <% if (typeof setPasswordError !== 'undefined' && setPasswordError) { %>
  <div class="sd-alert sd-alert--error">
    <i data-lucide="alert-circle"></i>
    <span>Could not set password. Try again below (min 6 characters).</span>
  </div>
  <% } %>
  <% if (typeof changePasswordError !== 'undefined' && changePasswordError) { %>
  <div class="sd-alert sd-alert--error">
    <i data-lucide="alert-circle"></i>
    <span>Could not change password. Check your current password and try again (new password min 6 characters).</span>
  </div>
  <% } %>

  <section class="sd-section">
    <h2 class="sd-section__title"><%= hasPassword ? 'Update your password' : 'Set your password' %></h2>
    <p class="sd-section__desc"><%= hasPassword ? 'Change your password' : 'Set a password to sign in next time with your email.' %></p>
    <div class="sd-section__body">
      <% if (hasPassword) { %>
      <form method="post" action="/student/dashboard/change-password" class="sd-form">
        <input type="hidden" name="email" value="<%= application.email %>">
        <input type="hidden" name="applicationId" value="<%= application.applicationId %>">
        <div class="sd-field">
          <label class="sd-field__label" for="current-password">Old password</label>
          <input type="password" id="current-password" name="currentPassword" class="sd-input" required autocomplete="current-password" placeholder="••••••••">
        </div>
        <div class="sd-field">
          <label class="sd-field__label" for="new-password">New password</label>
          <input type="password" id="new-password" name="newPassword" class="sd-input" required minlength="6" autocomplete="new-password" placeholder="••••••••">
          <span class="sd-field__hint">Min 6 characters</span>
        </div>
        <button type="submit" class="sd-btn sd-btn--primary">Update password</button>
      </form>
      <% } else { %>
      <form method="post" action="/student/dashboard/set-password" class="sd-form">
        <input type="hidden" name="email" value="<%= application.email %>">
        <input type="hidden" name="applicationId" value="<%= application.applicationId %>">
        <div class="sd-field">
          <label class="sd-field__label" for="new-password">New password</label>
          <input type="password" id="new-password" name="password" class="sd-input" required minlength="6" autocomplete="new-password" placeholder="••••••••">
          <span class="sd-field__hint">Min 6 characters</span>
        </div>
        <button type="submit" class="sd-btn sd-btn--primary">Set password</button>
      </form>
      <% } %>
    </div>
  </section>
</div>

<script>if (typeof lucide !== 'undefined') lucide.createIcons();</script>
