<div class="student-dash student-dash--login">
  <header class="student-dash__header">
    <h1 class="student-dash__title">Student login</h1>
    <p class="student-dash__desc">View your application with your Application ID, or sign in with your email and password.</p>
  </header>

  <div class="student-dash__tabs" role="tablist" aria-label="Sign in options">
    <button type="button" class="student-dash__tab <%= activeTab === 'view' ? 'student-dash__tab--active' : '' %>" role="tab" aria-selected="<%= activeTab === 'view' %>" aria-controls="panel-view" id="tab-view" data-tab="view">
      <i data-lucide="file-text"></i> View application
    </button>
    <button type="button" class="student-dash__tab <%= activeTab === 'login' ? 'student-dash__tab--active' : '' %>" role="tab" aria-selected="<%= activeTab === 'login' %>" aria-controls="panel-login" id="tab-login" data-tab="login">
      <i data-lucide="log-in"></i> Login
    </button>
  </div>

  <div class="student-dash__card">
    <% if (typeof error !== 'undefined' && error) { %>
    <p class="student-dash__error"><%= error %></p>
    <% } %>
    <div id="panel-view" class="student-dash__panel" role="tabpanel" aria-labelledby="tab-view"<%= activeTab !== 'view' ? ' hidden' : '' %>>
      <h2 class="student-dash__card-title">View with application ID</h2>
      <form method="post" action="/student/login" class="student-dash__form">
        <input type="hidden" name="mode" value="view">
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required placeholder="you@university.edu">
        </div>
        <div class="form-group">
          <label for="applicationId">Application ID</label>
          <input type="text" id="applicationId" name="applicationId" required placeholder="e.g. BD-XXXX">
        </div>
        <button type="submit" class="btn"><i data-lucide="search"></i> View application</button>
      </form>
    </div>

    <div id="panel-login" class="student-dash__panel" role="tabpanel" aria-labelledby="tab-login"<%= activeTab !== 'login' ? ' hidden' : '' %>>
      <h2 class="student-dash__card-title">Login with email and password</h2>
      <form method="post" action="/student/login" class="student-dash__form">
        <input type="hidden" name="mode" value="login">
        <div class="form-group">
          <label for="login-email">Email</label>
          <input type="email" id="login-email" name="email" required placeholder="you@university.edu" autocomplete="email">
        </div>
        <div class="form-group">
          <label for="login-password">Password</label>
          <input type="password" id="login-password" name="password" required autocomplete="current-password" placeholder="••••••••">
        </div>
        <button type="submit" class="btn"><i data-lucide="log-in"></i> Sign in</button>
      </form>
      <p class="student-dash__hint">Set a password first by viewing your application with your Application ID; then you can sign in here.</p>
    </div>
  </div>
</div>

<script>
(function() {
  var tabs = document.querySelectorAll('.student-dash__tab');
  var panels = document.querySelectorAll('.student-dash__panel');
  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var t = this.getAttribute('data-tab');
      tabs.forEach(function(x) { x.classList.remove('student-dash__tab--active'); x.setAttribute('aria-selected', 'false'); });
      panels.forEach(function(p) { p.hidden = true; });
      this.classList.add('student-dash__tab--active');
      this.setAttribute('aria-selected', 'true');
      var panel = document.getElementById('panel-' + t);
      if (panel) { panel.hidden = false; }
      if (typeof lucide !== 'undefined') lucide.createIcons();
    });
  });
})();
</script>
