<div class="header-top">
  <div class="header-top-inner">
    <div class="header-top-left">
      <a href="mailto:info@bridgedegree.com"><i data-lucide="mail"></i> info@bridgedegree.com</a>
    </div>
    <div class="header-top-right">
      <a href="/student/login"><i data-lucide="log-in"></i> Student Login</a>
    </div>
  </div>
</div>
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo-link">
      <img src="/images/logo.png" alt="BridgeDegree" class="header-logo">
    </a>
    <button type="button" class="menu-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-main">
      <span class="menu-toggle-bar"></span>
      <span class="menu-toggle-bar"></span>
      <span class="menu-toggle-bar"></span>
    </button>
    <nav class="nav-main" id="nav-main">
      <ul>
        <% const navKeys = ['index','students','partners','how_it_works','about','blog']; navKeys.forEach(function(key) { %>
        <li><a href="<%= routes[key].path %>" class="<%= currentRoute === key ? 'active' : '' %>"><%= routes[key].title %></a></li>
        <% }); %>
      </ul>
    </nav>
  </div>
</header>
