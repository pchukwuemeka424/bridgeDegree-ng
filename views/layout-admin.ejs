<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Admin' %> | BridgeDegree</title>
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/site.css">
  <link rel="stylesheet" href="/css/admin.css">
  <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="admin-body<%= typeof layoutNoHeader !== 'undefined' && layoutNoHeader ? ' admin-body--login' : '' %>">
<% if (typeof layoutNoHeader !== 'undefined' && layoutNoHeader) { %>
  <main class="admin-main admin-main--full">
    <%- body %>
  </main>
<% } else { %>
  <div class="admin-wrap">
    <aside class="admin-sidebar">
      <a href="/admin" class="admin-sidebar__logo">
        <img src="/images/logo.png" alt="Bridge Degree" class="admin-sidebar__logo-img">
      </a>
      <p class="admin-sidebar__nav-label">Navigation</p>
      <nav class="admin-sidebar__nav">
        <a href="/admin" class="admin-sidebar__link<%= typeof adminPage !== 'undefined' && adminPage === 'dashboard' ? ' admin-sidebar__link--active' : '' %>">
          <i data-lucide="layout-dashboard" class="admin-sidebar__icon"></i>
          <span>Dashboard</span>
        </a>
        <a href="/admin/blog" class="admin-sidebar__link<%= typeof adminPage !== 'undefined' && adminPage === 'blog' ? ' admin-sidebar__link--active' : '' %>">
          <i data-lucide="file-text" class="admin-sidebar__icon"></i>
          <span>Blog</span>
        </a>
        <a href="/admin/testimonials" class="admin-sidebar__link<%= typeof adminPage !== 'undefined' && adminPage === 'testimonials' ? ' admin-sidebar__link--active' : '' %>">
          <i data-lucide="message-square-quote" class="admin-sidebar__icon"></i>
          <span>Testimonials</span>
        </a>
        <a href="/admin/partners" class="admin-sidebar__link<%= typeof adminPage !== 'undefined' && adminPage === 'partners' ? ' admin-sidebar__link--active' : '' %>">
          <i data-lucide="building-2" class="admin-sidebar__icon"></i>
          <span>Partners</span>
        </a>
        <a href="/admin/hero" class="admin-sidebar__link<%= typeof adminPage !== 'undefined' && adminPage === 'hero' ? ' admin-sidebar__link--active' : '' %>">
          <i data-lucide="layout" class="admin-sidebar__icon"></i>
          <span>Home Hero</span>
        </a>
        <a href="/admin/applications" class="admin-sidebar__link<%= typeof adminPage !== 'undefined' && adminPage === 'applications' ? ' admin-sidebar__link--active' : '' %>">
          <i data-lucide="users" class="admin-sidebar__icon"></i>
          <span>Applications</span>
        </a>
        <div class="admin-sidebar__divider"></div>
        <a href="/" target="_blank" class="admin-sidebar__link">
          <i data-lucide="external-link" class="admin-sidebar__icon"></i>
          <span>View site</span>
        </a>
        <a href="/admin/logout" class="admin-sidebar__link">
          <i data-lucide="log-out" class="admin-sidebar__icon"></i>
          <span>Logout</span>
        </a>
      </nav>
    </aside>
    <div class="admin-right">
      <header class="admin-topbar">
        <a href="/admin" class="admin-topbar__left">
          <img src="/images/logo.png" alt="Bridge Degree" class="admin-topbar__logo-img">
          <span class="admin-topbar__logo-text">Admin</span>
        </a>
        <div class="admin-topbar__search">
          <i data-lucide="search" class="admin-topbar__search-icon"></i>
          <input type="text" placeholder="Search..." class="admin-topbar__search-input" aria-label="Search">
        </div>
        <div class="admin-topbar__right">
          <button type="button" class="admin-topbar__icon-btn" aria-label="Full screen"><i data-lucide="maximize-2"></i></button>
          <a href="/admin" class="admin-topbar__icon-btn" aria-label="Dashboard"><i data-lucide="layout-dashboard"></i></a>
          <div class="admin-topbar__user">
            <span class="admin-topbar__avatar"><i data-lucide="user"></i></span>
            <span class="admin-topbar__name">Admin</span>
            <i data-lucide="chevron-down" class="admin-topbar__chevron"></i>
          </div>
        </div>
      </header>
      <main class="admin-main">
        <%- body %>
      </main>
    </div>
  </div>
<% } %>
<script>if (typeof lucide !== 'undefined') lucide.createIcons();</script>
</body>
</html>
