<style>
  .contact-hero { padding: 64px 0 48px; text-align: center; background: #244267; border-bottom: 1px solid rgba(255,255,255,0.1); color: #fff; }
  .contact-hero h1 { font-family: 'DM Serif Display', serif; font-size: clamp(1.85rem, 3vw, 2.35rem); font-weight: 400; margin-bottom: 12px; color: #fff; }
  .contact-hero .subtitle { font-size: 1.1rem; color: rgba(255,255,255,0.92); max-width: 560px; margin: 0 auto 40px; }
  .contact-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; max-width: 900px; margin: 0 auto; }
  .contact-info { background: var(--surface-2); border-radius: var(--radius); padding: 32px; border: 1px solid var(--border); }
  .contact-info h2 { font-size: 1.15rem; font-weight: 700; margin-bottom: 20px; color: var(--text); }
  .contact-item { display: flex; align-items: flex-start; gap: 16px; margin-bottom: 24px; }
  .contact-item:last-child { margin-bottom: 0; }
  .contact-item .icon-wrap { width: 44px; height: 44px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; background: var(--accent-green-soft); border-radius: var(--radius-sm); color: var(--accent-green); }
  .contact-item .lucide, .contact-item .icon-wrap svg { width: 22px; height: 22px; display: block; }
  .contact-item a { color: var(--accent-green); font-weight: 600; text-decoration: none; }
  .contact-item a:hover { text-decoration: underline; }
  .contact-item p { font-size: 0.95rem; color: var(--text-muted); margin-top: 4px; line-height: 1.5; }
  .contact-form-wrap { background: var(--surface); padding: 40px; border-radius: var(--radius); box-shadow: var(--shadow); border: 1px solid var(--border); }
  .contact-form-wrap h2 { font-size: 1.15rem; font-weight: 700; margin-bottom: 24px; color: var(--text); }
  .contact-note { font-size: 0.9rem; color: var(--text-muted); margin-top: 20px; line-height: 1.5; }
  @media (max-width: 768px) { .contact-layout { grid-template-columns: 1fr; } }
</style>

<section class="contact-hero">
  <div class="container">
    <h1>Get in touch</h1>
    <p class="subtitle">Have a question about BridgeDegree, the programme, or partnerships? We're here to help. Reach out by email or send a message below.</p>
  </div>
</section>

<section class="page-section" style="padding-top: 0;">
  <div class="container">
    <div class="contact-layout">
      <div class="contact-info">
        <h2>Contact information</h2>
        <div class="contact-item">
          <div class="icon-wrap"><i data-lucide="mail"></i></div>
          <div>
            <a href="mailto:info@bridgedegree.com">info@bridgedegree.com</a>
            <p>For general enquiries, student applications, and partner interest.</p>
          </div>
        </div>
        <div class="contact-item">
          <div class="icon-wrap"><i data-lucide="mail"></i></div>
          <div>
            <a href="mailto:bridgedegree@gmail.com">bridgedegree@gmail.com</a>
            <p>Reach us on Gmail for any enquiries.</p>
          </div>
        </div>
        <div class="contact-item">
          <div class="icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </div>
          <div>
            <a href="https://www.facebook.com/bridgedegree" target="_blank" rel="noopener noreferrer">facebook.com/bridgedegree</a>
            <p>Follow us on Facebook for news and updates.</p>
          </div>
        </div>
        <div class="contact-item">
          <div class="icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </div>
          <div>
            <a href="https://www.instagram.com/bridgedegree" target="_blank" rel="noopener noreferrer">@bridgedegree on Instagram</a>
            <p>Photos, stories, and updates from the community.</p>
          </div>
        </div>
        <div class="contact-item">
          <div class="icon-wrap"><i data-lucide="clock"></i></div>
          <div>
            <span style="font-weight: 600; color: var(--text);">Response time</span>
            <p>We aim to respond within 48 hours for applications and within 2 business days for partnership enquiries.</p>
          </div>
        </div>
      </div>

      <div class="contact-form-wrap">
        <h2>Send a message</h2>
        <form id="contactForm" action="#" method="post">
          <div class="form-row">
            <div class="form-group">
              <label for="name">Name *</label>
              <input type="text" id="name" name="name" required placeholder="Your name">
            </div>
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required placeholder="your@email.com">
            </div>
          </div>
          <div class="form-group">
            <label for="subject">Subject</label>
            <select id="subject" name="subject">
              <option value="">Select a topic</option>
              <option value="Student enquiry">Student enquiry</option>
              <option value="Partner enquiry">Partner enquiry</option>
              <option value="University / Advocate">University / Advocate</option>
              <option value="Press / Media">Press / Media</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Message *</label>
            <textarea id="message" name="message" required placeholder="How can we help?" minlength="10"></textarea>
          </div>
          <button type="submit" class="btn-primary">Send message</button>
        </form>
        <div class="form-success" id="contactSuccess">Thank you for your message. We'll get back to you within 48 hours.</div>
        <p class="contact-note">If you're ready to apply as a student or partner, use the dedicated forms on the <a href="/students">Students</a> or <a href="/partners">Partners</a> pages for a faster response.</p>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById('contactForm').addEventListener('submit', function(e) {
    e.preventDefault();
    this.style.display = 'none';
    document.getElementById('contactSuccess').classList.add('show');
  });
</script>
