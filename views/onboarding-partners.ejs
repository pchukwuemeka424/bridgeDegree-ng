  .tier-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 24px; }
  .tier-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 28px 24px; }
  .tier-card h4 { font-size: 1.1rem; font-weight: 700; margin-bottom: 12px; color: var(--accent-green); }
  .tier-card p { font-size: 0.9rem; color: var(--text-muted); line-height: 1.6; }
  .commit-list { list-style: none; margin-top: 16px; }
  .commit-list li { position: relative; padding-left: 24px; margin-bottom: 10px; font-size: 0.95rem; color: var(--text-muted); line-height: 1.5; }
  .commit-list li::before { content: '✓'; position: absolute; left: 0; color: var(--accent-green); font-weight: 700; }
  @media (max-width: 1024px) { .tier-grid { grid-template-columns: 1fr; } }
