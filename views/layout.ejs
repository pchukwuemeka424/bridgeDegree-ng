<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'BridgeDegree' %> | Nigeria's Career Infrastructure Platform</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/site.css">
  <% if (typeof stylesheet !== 'undefined' && stylesheet) { %>
  <link rel="stylesheet" href="/css/<%= stylesheet %>.css">
  <% } %>
  <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
  <%- include('partials/header') %>
  <%- include('partials/breadcrumb') %>
  <main>
    <%- body %>
  </main>
  <%- include('partials/footer') %>
  <%- include('partials/legal-footer') %>
  <script>lucide.createIcons();</script>
  <% if (typeof extraJs !== 'undefined' && extraJs) { %><%- extraJs %><% } %>
</body>
</html>
