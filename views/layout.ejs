<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <% var _desc = (typeof metaDescription !== 'undefined' && metaDescription) ? metaDescription : (seo.searchDescription || seo.defaultDescription); %>
  <% var _docTitle = documentTitle(typeof title !== 'undefined' ? title : undefined); %>
  <title><%= _docTitle %></title>
  <meta name="description" content="<%= _desc %>">
  <meta name="keywords" content="<%= typeof metaKeywords !== 'undefined' && metaKeywords ? metaKeywords : seo.keywords %>">
  <% if (typeof robotsMeta === 'string' && robotsMeta) { %>
  <meta name="robots" content="<%= robotsMeta %>">
  <% } %>
  <link rel="canonical" href="<%= canonicalUrl %>">
  <meta property="og:type" content="<%= typeof ogType !== 'undefined' && ogType ? ogType : 'website' %>">
  <meta property="og:url" content="<%= canonicalUrl %>">
  <meta property="og:title" content="<%= _docTitle %>">
  <meta property="og:description" content="<%= _desc %>">
  <meta property="og:locale" content="en_NG">
  <meta property="og:site_name" content="<%= seo.siteName %>">
  <% if (typeof ogImageUrl === 'string' && ogImageUrl) { %>
  <meta property="og:image" content="<%= ogImageUrl %>">
  <meta property="og:image:alt" content="<%= typeof ogImageAlt !== 'undefined' && ogImageAlt ? ogImageAlt : _docTitle %>">
  <% } %>
  <% if (ogType === 'article' && articlePublishedTime) { %>
  <meta property="article:published_time" content="<%= articlePublishedTime %>">
  <% } %>
  <% if (ogType === 'article' && articleModifiedTime) { %>
  <meta property="article:modified_time" content="<%= articleModifiedTime %>">
  <% } %>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= _docTitle %>">
  <meta name="twitter:description" content="<%= _desc %>">
  <% if (typeof ogImageUrl === 'string' && ogImageUrl) { %>
  <meta name="twitter:image" content="<%= ogImageUrl %>">
  <% } %>
  <% if (seo.twitterSite) { %>
  <meta name="twitter:site" content="<%= seo.twitterSite %>">
  <% } %>
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <% if (typeof jsonLd === 'string' && jsonLd) { %>
  <script type="application/ld+json"><%- jsonLd %></script>
  <% } %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/site.css">
  <% if (typeof stylesheet !== 'undefined' && stylesheet) { %>
  <link rel="stylesheet" href="/css/<%= stylesheet %>.css">
  <% } %>
  <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
  <%- include('partials/header') %>
  <%- include('partials/breadcrumb') %>
  <main>
    <%- body %>
  </main>
  <%- include('partials/footer') %>
  <%- include('partials/legal-footer') %>
  <script>lucide.createIcons();</script>
  <script>
    (function() {
      var toggle = document.querySelector('.menu-toggle');
      var header = document.querySelector('.site-header');
      if (toggle && header) {
        toggle.addEventListener('click', function() {
          var open = header.classList.toggle('menu-open');
          toggle.setAttribute('aria-expanded', open);
        });
        document.querySelectorAll('.nav-main a').forEach(function(link) {
          link.addEventListener('click', function() { header.classList.remove('menu-open'); toggle.setAttribute('aria-expanded', 'false'); });
        });
      }
    })();
  </script>
  <% if (typeof extraJs !== 'undefined' && extraJs) { %><%- extraJs %><% } %>
</body>
</html>
