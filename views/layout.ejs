<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : seo.siteName %> | <%= seo.tagline %></title>
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : seo.defaultDescription %>">
  <meta name="keywords" content="<%= typeof metaKeywords !== 'undefined' && metaKeywords ? metaKeywords : seo.keywords %>">
  <link rel="canonical" href="<%= canonicalUrl %>">
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= canonicalUrl %>">
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : seo.siteName %> | <%= seo.tagline %>">
  <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : seo.defaultDescription %>">
  <meta property="og:locale" content="en_NG">
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title : seo.siteName %> | <%= seo.tagline %>">
  <meta name="twitter:description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : seo.defaultDescription %>">
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/site.css">
  <% if (typeof stylesheet !== 'undefined' && stylesheet) { %>
  <link rel="stylesheet" href="/css/<%= stylesheet %>.css">
  <% } %>
  <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
  <%- include('partials/header') %>
  <%- include('partials/breadcrumb') %>
  <main>
    <%- body %>
  </main>
  <%- include('partials/footer') %>
  <%- include('partials/legal-footer') %>
  <script>lucide.createIcons();</script>
  <% if (typeof extraJs !== 'undefined' && extraJs) { %><%- extraJs %><% } %>
</body>
</html>
