<% const h = (typeof hero !== 'undefined' && hero) ? hero : {}; %>
<section class="hero-wrapper" id="home">
  <div class="hero-bg">
    <img src="<%= h.bgImage || '/images/banna.jpg' %>" alt="Graduates celebrating – BridgeDegree">
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-inner">
    <div class="hero-badge">
      <i data-lucide="graduation-cap"></i>
      <%= h.badgeText || "Nigeria's Career Infrastructure Platform" %>
    </div>
    <h1 class="hero-title"><%= h.title || 'Graduate with' %> <span><%= h.titleHighlight || 'proof' %></span></h1>
    <p class="hero-desc"><%= h.description || 'BridgeDegree embeds verified work experience, published research, and global career pathways directly into your university years, starting from 100 Level.' %></p>
    <div class="hero-ctas">
      <a href="<%= h.ctaUrl || '/students/apply#apply' %>" class="hero-btn hero-btn-main"><%= h.ctaText || 'Get Started' %> <i data-lucide="rocket"></i></a>
    </div>
  </div>
  <a href="#problem" class="hero-scroll" aria-label="Scroll to content">
    <i data-lucide="chevron-down"></i>
    Scroll
  </a>
</section>

<section class="section problem-section" id="problem">
  <div class="problem-inner">
    <div class="problem-wrap">
      <div class="problem-panel">
        <h2 class="problem-title">The Problem</h2>
        <p class="problem-intro">Most students graduate with:</p>
        <div class="problem-cards">
          <div class="problem-card">
            <div class="icon"><i data-lucide="file-text"></i></div>
            <h3>No Verifiable Work History</h3>
            <p>Degrees signal intent, not capability. Without documented experience, graduates are indistinguishable globally.</p>
          </div>
          <div class="problem-card">
            <div class="icon"><i data-lucide="package-search"></i></div>
            <h3>Research That Goes Nowhere</h3>
            <p>Final-year projects are written, submitted, and shelved. Years of work never reach a journal or an employer.</p>
          </div>
          <div class="problem-card">
            <div class="icon"><i data-lucide="clock"></i></div>
            <h3>A CV Built in the Final Year</h3>
            <p>Most students begin thinking about their careers too late, with their undergraduate years behind them and little to show for it.</p>
          </div>
        </div>
      </div>
      <div class="problem-image">
        <img src="/images/pro.jpg" alt="The problem – BridgeDegree">
      </div>
    </div>
  </div>
</section>

<section class="section solution-section" id="solution">
  <div class="solution-inner">
    <div class="solution-wrap">
      <div class="solution-image">
        <img src="/images/left.jpg" alt="The solution – BridgeDegree">
      </div>
      <div class="solution-panel">
        <h2 class="solution-title">The Solution</h2>
        <p class="solution-intro">Four engines. One integrated career framework. BridgeDegree embeds directly into your academic timeline. Each engine produces verifiable output. Each output becomes a permanent asset in your Career Passport.</p>
        <div class="solution-cards">
          <div class="solution-card">
            <div class="icon"><i data-lucide="briefcase"></i></div>
            <h3>Work Experience Engine</h3>
            <p>Real experience before you graduate</p>
          </div>
          <div class="solution-card">
            <div class="icon"><i data-lucide="megaphone"></i></div>
            <h3>Publication Pipeline</h3>
            <p>Your research, published and cited</p>
          </div>
          <div class="solution-card">
            <div class="icon"><i data-lucide="globe"></i></div>
            <h3>Global Mobility Framework</h3>
            <p>A structured path to the world</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="after-section" id="after">
  <div class="after-inner">
    <div class="after-content">
      <h2 class="after-title">BridgeDegree After</h2>
      <p class="after-tagline">Make your service year count twice</p>
      <p class="after-desc">Most corps members treat the NYSC year as a pause. BridgeDegree After treats it as a 12-month structured opportunity to place internationally, build remotely, and document everything for global recruiters before POP.</p>
      <p class="after-built">Built by Nigerians, for Nigerians, who have lived the painful gap between earning a degree and gaining real global leverage.</p>
      <a href="#" class="btn-learn after-cta" id="after-learn-more">Learn More <i data-lucide="arrow-right"></i></a>
    </div>
  </div>
</section>

<div class="modal-overlay" id="after-modal" aria-hidden="true" role="dialog" aria-labelledby="after-modal-title">
  <div class="modal-backdrop" id="after-modal-backdrop"></div>
  <div class="modal-box" role="document">
    <button type="button" class="modal-close" id="after-modal-close" aria-label="Close">
      <i data-lucide="x"></i>
    </button>
    <h2 class="modal-title" id="after-modal-title">BridgeDegree After — NYSC & Postgraduate Pathway</h2>
    <p class="modal-intro">Whether you're in camp, posted to a state, or navigating a Master's programme, BridgeDegree After meets you exactly where you are.</p>
    <h3 class="modal-subtitle">⬡ NYSC Corps Members</h3>
    <p class="modal-lead">Make your service year count twice.</p>
    <p class="modal-p">Most corps members treat the NYSC year as a pause. BridgeDegree After treats it as a 12-month structured opportunity to place internationally, build remotely, and document everything for global recruiters before POP.</p>
    <ul class="modal-list">
      <li>Profile/Academic Assessment</li>
      <li>Certifications/Mentoring</li>
      <li>Work positioning while on posting</li>
      <li>International job applications during service</li>
      <li>Career Passport upgraded with NYSC placement data</li>
      <li>Study-abroad application support (deadlines often fall within service)</li>
      <li>Post-placement 90-day check-in and career review</li>
      <li>Final Project conversion to publication support</li>
      <li>Career/academic examinations support</li>
      <li>Master's degree counselling</li>
    </ul>
  </div>
</div>

<section class="career-passport-section" id="career-passport">
  <div class="career-passport-inner">
    <div class="career-passport-wrap">
      <div class="career-passport-content">
        <h2 class="career-passport-title">Career Passport</h2>
        <p class="career-passport-desc">Your verified work history, published research, and global pathway — in one portable, employer-ready profile.</p>
        <p class="career-passport-more">Everything you build with BridgeDegree during university and after (including NYSC) is documented and verifiable in your Career Passport. Recruiters and institutions see proof, not just claims — so you stand out locally and globally.</p>
        <ul class="career-passport-list">
          <li>Verified work experience and placements</li>
          <li>Published research and final-year project conversion</li>
          <li>Certifications, skills, and NYSC outcomes</li>
          <li>Study-abroad and postgraduate application trail</li>
        </ul>
        <a href="/career-passport" class="btn-learn career-passport-cta">Explore Career Passport <i data-lucide="arrow-right"></i></a>
      </div>
      <div class="cp-sample">
        <div class="cp-sample-label">Sample — Career Passport</div>
        <div class="cp-sample-inner">
          <div class="cp-sample-header">
            <div class="cp-sample-avatar"><img src="/images/avatar-female.svg" alt=""></div>
            <div>
              <div class="cp-sample-name">Amina O.</div>
              <div class="cp-sample-meta">Computer Science, 400 Level</div>
              <div class="cp-sample-meta">University of Lagos</div>
            </div>
          </div>
          <div class="cp-sample-badges">
            <span class="cp-sample-badge"><i data-lucide="shield-check"></i> Verified</span>
            <span class="cp-sample-badge"><i data-lucide="briefcase"></i> 2 placements</span>
          </div>
          <div class="cp-sample-block">
            <h4>Work experience</h4>
            <div class="item">Product Intern — Tech Co. (Verified)</div>
            <div class="item">SIWES — Fintech (Verified)</div>
          </div>
          <div class="cp-sample-block">
            <h4>Research</h4>
            <p>1 publication: “Machine learning in fraud detection” — submitted to journal</p>
          </div>
          <div class="cp-sample-block">
            <h4>Pathway</h4>
            <p>Study-abroad applications in progress; Career Passport shared with 3 recruiters.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<% const partnerList = (typeof partners !== 'undefined' && partners && partners.length) ? partners : []; %>
<section class="partners-section" id="partners" aria-label="Our partners">
  <div class="partners-inner">
    <h2 class="partners-title">Our Partners</h2>
    <div class="partners-carousel-wrap">
      <div class="partners-carousel">
        <% if (partnerList.length) { %>
          <% partnerList.forEach(function(p) { %>
        <% if (p.link) { %><a href="<%= p.link %>" target="_blank" rel="noopener noreferrer" class="partner-logo-wrap"><% } %><img src="<%= p.logo %>" alt="<%= p.name %>" class="partner-logo"><% if (p.link) { %></a><% } %>
          <% }); %>
          <% partnerList.forEach(function(p) { %>
        <% if (p.link) { %><a href="<%= p.link %>" target="_blank" rel="noopener noreferrer" class="partner-logo-wrap"><% } %><img src="<%= p.logo %>" alt="" class="partner-logo" aria-hidden="true"><% if (p.link) { %></a><% } %>
          <% }); %>
        <% } else { %>
        <img src="/images/p-1.png" alt="Partner 1" class="partner-logo">
        <img src="/images/p-2.jpeg" alt="Partner 2" class="partner-logo">
        <img src="/images/p-3.png" alt="Partner 3" class="partner-logo">
        <img src="/images/p-1.png" alt="" class="partner-logo" aria-hidden="true">
        <img src="/images/p-2.jpeg" alt="" class="partner-logo" aria-hidden="true">
        <img src="/images/p-3.png" alt="" class="partner-logo" aria-hidden="true">
        <% } %>
      </div>
    </div>
  </div>
</section>

<section class="section testimonials-section" id="testimonials" aria-label="Testimonials">
  <div class="testimonials-inner">
    <h2 class="testimonials-title">What People Say</h2>
    <p class="testimonials-subtitle">Stories from students and partners who use BridgeDegree.</p>
    <% const tList = (typeof testimonials !== 'undefined' && testimonials && testimonials.length) ? testimonials : [
      { quote: "BridgeDegree gave me a real portfolio before I graduated. My Career Passport landed me interviews I wouldn't have gotten otherwise.", name: "Chioma O.", role: "Graduate", location: "Lagos" },
      { quote: "We needed a way to make our students visible to employers. BridgeDegree's framework integrated seamlessly with our curriculum.", name: "Dr. Adebayo", role: "University Partner", location: "" },
      { quote: "The publication pipeline turned my final-year project into a citable asset. It's now part of my professional identity.", name: "Emeka N.", role: "Student", location: "Abuja" },
      { quote: "Hiring from BridgeDegree profiles is efficient. We see verified experience and work history, not just degrees.", name: "HR Lead", role: "Partner Organisation", location: "" }
    ]; %>
    <div class="testimonial-slider" data-testimonial-slider>
      <button type="button" class="t-nav t-prev" aria-label="Previous testimonial" data-t-prev>
        <i data-lucide="chevron-left"></i>
      </button>
      <div class="testimonial-viewport" data-t-viewport tabindex="0" aria-label="Testimonials carousel">
        <div class="testimonial-track" data-t-track>
          <% tList.forEach(function(t) { %>
          <article class="testimonial-card">
            <blockquote><%= t.quote %></blockquote>
            <cite><strong><%= t.name %></strong><%= (t.role || t.location) ? ' — ' : '' %><%= [t.role, t.location].filter(Boolean).join(', ') %></cite>
          </article>
          <% }); %>
        </div>
      </div>
      <button type="button" class="t-nav t-next" aria-label="Next testimonial" data-t-next>
        <i data-lucide="chevron-right"></i>
      </button>
    </div>
  </div>
</section>

<section class="section blog-snippet-section" id="blog">
  <div class="blog-snippet-inner">
    <h2 class="blog-snippet-title">Blog</h2>
    <p class="blog-snippet-subtitle">Insights on career infrastructure, graduate outcomes, and building proof — not just credentials.</p>
    <div class="blog-snippet-grid">
      <% const pList = (typeof homePosts !== 'undefined' && homePosts && homePosts.length) ? homePosts : []; %>
      <% if (pList.length) { %>
        <% pList.forEach(function(p) { %>
        <article class="blog-snippet-card">
          <a href="/blog/<%= p.slug %>">
            <div class="card-inner">
              <div class="meta"><span class="tag">Blog</span><span><%= p.createdAt ? new Date(p.createdAt).toLocaleDateString('en-GB', { month: 'long', year: 'numeric' }) : '' %></span></div>
              <h3><%= p.title %></h3>
              <p><%= p.excerpt || (p.content ? p.content.slice(0, 160) + '…' : '') %></p>
            </div>
          </a>
        </article>
        <% }); %>
      <% } else { %>
        <article class="blog-snippet-card" style="grid-column: 1 / -1;">
          <a href="/blog">
            <div class="card-inner">
              <div class="meta"><span class="tag">Blog</span></div>
              <h3>Read our latest updates</h3>
              <p>No posts yet. Check back soon.</p>
            </div>
          </a>
        </article>
      <% } %>
    </div>
    <div class="blog-snippet-cta">
      <a href="/blog" class="btn-learn">View all posts <i data-lucide="arrow-right"></i></a>
    </div>
  </div>
</section>

<script>
(function() {
  var modal = document.getElementById('after-modal');
  var openBtn = document.getElementById('after-learn-more');
  var closeBtn = document.getElementById('after-modal-close');
  var backdrop = document.getElementById('after-modal-backdrop');
  function openModal(e) {
    if (e) e.preventDefault();
    if (!modal) return;
    modal.setAttribute('aria-hidden', 'false');
    modal.classList.add('modal-open');
    document.body.style.overflow = 'hidden';
    if (closeBtn) closeBtn.focus();
    lucide.createIcons();
  }
  function closeModal() {
    if (!modal) return;
    modal.setAttribute('aria-hidden', 'true');
    modal.classList.remove('modal-open');
    document.body.style.overflow = '';
    if (openBtn) openBtn.focus();
  }
  if (openBtn) openBtn.addEventListener('click', openModal);
  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  if (backdrop) backdrop.addEventListener('click', closeModal);
  modal.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeModal();
  });
})();
</script>

<script>
(function() {
  var root = document.querySelector('[data-testimonial-slider]');
  if (!root) return;
  var viewport = root.querySelector('[data-t-viewport]');
  var track = root.querySelector('[data-t-track]');
  var prev = root.querySelector('[data-t-prev]');
  var next = root.querySelector('[data-t-next]');
  if (!viewport || !track) return;

  function getStep() {
    var first = track.querySelector('.testimonial-card');
    if (!first) return 360;
    var styles = window.getComputedStyle(track);
    var gap = parseFloat(styles.columnGap || styles.gap || '0') || 0;
    return first.getBoundingClientRect().width + gap;
  }

  function scrollByDir(dir) {
    viewport.scrollBy({ left: dir * getStep(), behavior: 'smooth' });
  }

  function clampNav() {
    if (!prev || !next) return;
    var max = viewport.scrollWidth - viewport.clientWidth - 2;
    prev.disabled = viewport.scrollLeft <= 2;
    next.disabled = viewport.scrollLeft >= max;
  }

  if (prev) prev.addEventListener('click', function() { scrollByDir(-1); });
  if (next) next.addEventListener('click', function() { scrollByDir(1); });
  viewport.addEventListener('scroll', function() { window.requestAnimationFrame(clampNav); }, { passive: true });

  // Keyboard support
  viewport.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowLeft') { e.preventDefault(); scrollByDir(-1); }
    if (e.key === 'ArrowRight') { e.preventDefault(); scrollByDir(1); }
  });

  // Drag/swipe support
  var isDown = false;
  var startX = 0;
  var startLeft = 0;
  viewport.addEventListener('pointerdown', function(e) {
    isDown = true;
    startX = e.clientX;
    startLeft = viewport.scrollLeft;
    viewport.setPointerCapture(e.pointerId);
  });
  viewport.addEventListener('pointermove', function(e) {
    if (!isDown) return;
    var dx = e.clientX - startX;
    viewport.scrollLeft = startLeft - dx;
  });
  viewport.addEventListener('pointerup', function() { isDown = false; });
  viewport.addEventListener('pointercancel', function() { isDown = false; });

  window.addEventListener('resize', clampNav);
  clampNav();
})();
</script>
